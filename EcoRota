// SEÇÃO 7: FUNÇÕES DE INTERFACE - DETALHES
// ============================================

/**
 * Exibe os detalhes de uma lixeira selecionada
 * @param {object} lixeira - Dados da lixeira
 */
function exibirDetalhesSelecionada(lixeira) {
    // Define a cor da barra de progresso baseado no status
    let classeProgresso = '';
    if (lixeira.status === 'critical') {
        classeProgresso = 'critical';
    } else if (lixeira.status === 'warning') {
        classeProgresso = 'warning';
    }

    // Monta o HTML com os detalhes
    const html = `
        <div class="detalhe-item">
            <div class="detalhe-label">Nome</div>
            <div class="detalhe-valor">${lixeira.nome}</div>
        </div>
        <div class="detalhe-item">
            <div class="detalhe-label">Nível de Preenchimento</div>
            <div class="detalhe-valor">${lixeira.fillLevel.toFixed(0)}%</div>
            <div class="progress-bar">
                <div class="progress-fill ${classeProgresso}" style="width: ${lixeira.fillLevel}%"></div>
            </div>
        </div>
        <div class="detalhe-item">
            <div class="detalhe-label">Status</div>
            <div class="detalhe-valor">${getStatusLabel(lixeira.status)}</div>
        </div>
        <div class="detalhe-item">
            <div class="detalhe-label">Última Atualização</div>
            <div class="detalhe-valor">${lixeira.lastUpdated}</div>
        </div>
        <div class="detalhe-item">
            <div class="detalhe-label">Coordenadas</div>
            <div class="detalhe-valor">${lixeira.lat.toFixed(4)}, ${lixeira.lng.toFixed(4)}</div>
        </div>
    `;

    document.getElementById('detalhes-conteudo').innerHTML = html;
}

/**
 * Retorna o rótulo de status em português
 * @param {string} status - Status da lixeira
 * @returns {string} Rótulo do status
 */
function getStatusLabel(status) {
    const labels = {
        'critical': '🔴 Crítico',
        'warning': '🟡 Atenção',
        'empty': '🟢 Vazio'
    };
    return labels[status] || status;
}

