// SEÇÃO 8: FUNÇÕES DE INTERFACE - LISTAS
// ============================================

/**
 * Atualiza a lista de todas as lixeiras na interface
 */
function atualizarListaLixeiras() {
    const container = document.getElementById('lista-lixeiras');
    
    // Monta o HTML com cada lixeira
    const html = lixeiras.map(lixeira => `
        <div class="lixeira-item ${lixeira.status}" onclick="selecionarLixeira('${lixeira.id}')">
            <div class="lixeira-nome">${lixeira.nome}</div>
            <div class="lixeira-nivel">Preenchimento: ${lixeira.fillLevel.toFixed(0)}%</div>
            <div class="progress-bar">
                <div class="progress-fill ${lixeira.status === 'critical' ? 'critical' : lixeira.status === 'warning' ? 'warning' : ''}" 
                     style="width: ${lixeira.fillLevel}%"></div>
            </div>
        </div>
    `).join('');

    container.innerHTML = html;
}

/**
 * Seleciona uma lixeira ao clicar na lista
 * @param {string} id - ID da lixeira
 */
function selecionarLixeira(id) {
    const lixeira = lixeiras.find(l => l.id === id);
    if (lixeira) {
        lixeiraSelecionada = lixeira;
        exibirDetalhesSelecionada(lixeira);
    }
}

/**
 * Atualiza a lista de rotas na interface
 */
function atualizarListaRotas() {
    const container = document.getElementById('lista-rotas');
    
    // Monta o HTML com cada rota
    const html = rotas.map(rota => `
        <div class="rota-item" onclick="selecionarRota('${rota.id}')">
            <div class="rota-nome">${rota.nome}</div>
            <div class="rota-info">⏱️ ${rota.tempoEstimado}</div>
            <div class="rota-info">📏 ${rota.distancia}</div>
            <div class="rota-info">⛽ ${rota.combustivel}</div>
        </div>
    `).join('');

    container.innerHTML = html;
}

/**
 * Seleciona uma rota ao clicar na lista
 * @param {string} id - ID da rota
 */
function selecionarRota(id) {
    const rota = rotas.find(r => r.id === id);
    if (rota) {
        exibirRotaNoMapa(rota);
    }
}

